local function selectTab(name)
    if currentTabName==name then return end
    currentTabName=name; clearContent(); BreadcrumbLabel.Text=name:upper()
    for _,entry in ipairs(allSideItems) do
        local isActive=entry.name==name
        entry.accent.Visible=isActive
        entry.lbl.Font=isActive and Enum.Font.GothamBold or Enum.Font.GothamMedium
        entry.icon.TextColor3=isActive and C_ACCENT() or C_MUTED()
        TweenService:Create(entry.lbl,TweenInfo.new(0.12),{TextColor3=isActive and C_TEXT() or C_MUTED()}):Play()
        if isActive then TweenService:Create(entry.item,TweenInfo.new(0.12),{BackgroundColor3=Color3.fromRGB(22,30,48),BackgroundTransparency=0}):Play()
        else TweenService:Create(entry.item,TweenInfo.new(0.12),{BackgroundTransparency=1}):Play() end
    end
    if allTabFrames[name] then allTabFrames[name]() end
    buildQuickPanel()
end

local function setSideItemBadge(name,visible)
    for _,entry in ipairs(allSideItems) do
        if entry.name==name and entry.badge then entry.badge.Visible=visible end
    end
end

local function registerSideItem(parent,name,displayText,icon,order)
    local item,accent,lbl,iconLbl,badge=makeSideItem(parent,displayText,icon,order,function() selectTab(name) end)
    table.insert(allSideItems,{name=name,item=item,accent=accent,lbl=lbl,icon=iconLbl,badge=badge})
    return item
end

