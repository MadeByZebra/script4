TooltipFrame.Size=UDim2.new(0,180,0,32); TooltipFrame.BackgroundColor3=C_PANEL()
TooltipFrame.BorderSizePixel=0; TooltipFrame.Visible=false; TooltipFrame.ZIndex=10
makeRound(TooltipFrame,6); makeStroke(TooltipFrame,C_STROKE(),1)
local TooltipLabel=Instance.new("TextLabel",TooltipFrame)
TooltipLabel.Size=UDim2.new(1,-12,1,0); TooltipLabel.Position=UDim2.new(0,6,0,0)
TooltipLabel.BackgroundTransparency=1; TooltipLabel.TextColor3=C_TEXT(); TooltipLabel.TextSize=fs(10)
TooltipLabel.Font=Enum.Font.Gotham; TooltipLabel.TextXAlignment=Enum.TextXAlignment.Left; TooltipLabel.TextWrapped=true

local tooltipThread=nil
local function showTooltip(text,guiObject)
    if tooltipThread then task.cancel(tooltipThread) end
    tooltipThread=task.delay(0.6,function()
        if not guiObject or not guiObject.Parent then return end
        local ap=guiObject.AbsolutePosition; local as=guiObject.AbsoluteSize
        TooltipLabel.Text=text
        local tw=math.min(180,#text*6.5+16)
        TooltipFrame.Size=UDim2.new(0,tw,0,32)
        local x=math.min(ap.X+as.X/2-tw/2,workspace.CurrentCamera.ViewportSize.X-tw-10)
        TooltipFrame.Position=UDim2.new(0,math.max(5,x),0,ap.Y-38); TooltipFrame.Visible=true
    end)
end
local function hideTooltip()
    if tooltipThread then task.cancel(tooltipThread); tooltipThread=nil end
    TooltipFrame.Visible=false
end
local function attachTooltip(obj,text)
    obj.MouseEnter:Connect(function() showTooltip(text,obj) end)
    obj.MouseLeave:Connect(function() hideTooltip() end)
end

