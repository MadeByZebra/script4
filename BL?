local function makeToggleRow(card,labelText,order,defaultOn,callback,tooltipText,featureKey)
    local row,lbl,div=makeFeatureRow(card,labelText,order)
    if featureKey then
        local starBtn=Instance.new("TextButton",row); starBtn.Size=UDim2.new(0,16,0,16)
        starBtn.Position=UDim2.new(0,-2,0.5,-8); starBtn.BackgroundTransparency=1
        starBtn.Text=isFavorite(featureKey) and "★" or "☆"
        starBtn.TextColor3=isFavorite(featureKey) and C_YELLOW or C_MUTED()
        starBtn.TextSize=fs(12); starBtn.Font=Enum.Font.GothamBold; starBtn.ZIndex=3
        starBtn.MouseButton1Click:Connect(function()
            toggleFavorite(featureKey); starBtn.Text=isFavorite(featureKey) and "★" or "☆"
            starBtn.TextColor3=isFavorite(featureKey) and C_YELLOW or C_MUTED()
        end)
        lbl.Position=UDim2.new(0,20,0,0); lbl.Size=UDim2.new(1,-72,1,0)
    else lbl.Size=UDim2.new(1,-56,1,0) end
    local switchBg=Instance.new("Frame",row); switchBg.Size=UDim2.new(0,38,0,20)
    switchBg.Position=UDim2.new(1,-46,0.5,-10)
    switchBg.BackgroundColor3=defaultOn and C_ACCENT() or Color3.fromRGB(45,50,65)
    switchBg.BorderSizePixel=0; makeRound(switchBg,10); makeStroke(switchBg,defaultOn and C_ACCENT_DK() or C_STROKE(),1)
    local thumb=Instance.new("Frame",switchBg); thumb.Size=UDim2.new(0,16,0,16)
    thumb.Position=defaultOn and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
    thumb.BackgroundColor3=Color3.fromRGB(255,255,255); thumb.BorderSizePixel=0; makeRound(thumb,8)
    local state=defaultOn
    local hitbox=Instance.new("TextButton",row); hitbox.Size=UDim2.new(1,0,1,0)
    hitbox.BackgroundTransparency=1; hitbox.Text=""; hitbox.ZIndex=2
    if tooltipText then attachTooltip(hitbox,tooltipText) end
    hitbox.MouseButton1Click:Connect(function()
        state=not state
        TweenService:Create(switchBg,TweenInfo.new(0.18),{BackgroundColor3=state and C_ACCENT() or Color3.fromRGB(45,50,65)}):Play()
        local sw=switchBg:FindFirstChildOfClass("UIStroke")
        if sw then TweenService:Create(sw,TweenInfo.new(0.18),{Color=state and C_ACCENT_DK() or C_STROKE()}):Play() end
        TweenService:Create(thumb,TweenInfo.new(0.18,Enum.EasingStyle.Quart),{Position=state and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)}):Play()
        if callback then callback(state) end
        logAction((state and "ON" or "OFF").." — "..labelText)
    end)
    local function set(val)
        state=val; switchBg.BackgroundColor3=val and C_ACCENT() or Color3.fromRGB(45,50,65)
        local sw=switchBg:FindFirstChildOfClass("UIStroke"); if sw then sw.Color=val and C_ACCENT_DK() or C_STROKE() end
        thumb.Position=val and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8)
    end
    return row,set
end

