local autoClashThread,alreadyExited=nil,false
startAutoClash = function()
    if autoClashThread then return end; alreadyExited=false
    autoClashThread=task.spawn(function()
        while ClashSettings.AutoClash do
            local ZN=getZN()
            if ZN then
                local done=allButtonsDone(ZN); setSideItemBadge("clash",not done and ClashSettings.AutoClash)
