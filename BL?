local function saveProfile(name)
    pcall(function()
        ensureFolder("ZebraBoxingLeague"); ensureFolder(PROFILE_FOLDER)
        local data={
            RejoinDelay=AutoRejoin.Delay, RejoinMethod=AutoRejoin.Method,
            RejoinLoad=AutoRejoin.LoadScript, Theme=CurrentThemeName,
            FontSizeMode=UISettings.FontSizeMode, CompactSidebar=UISettings.CompactSidebar,
        }
        writefile(PROFILE_FOLDER.."/"..name..".json", HttpService:JSONEncode(data))
    end)
end
local function loadProfile(name)
    local ok=false
    pcall(function()
        local path=PROFILE_FOLDER.."/"..name..".json"
        if not isfile(path) then return end
        local data=HttpService:JSONDecode(readfile(path))
        if data.RejoinDelay    then AutoRejoin.Delay       = data.RejoinDelay end
        if data.RejoinMethod   then AutoRejoin.Method      = data.RejoinMethod end
        if data.RejoinLoad~=nil then AutoRejoin.LoadScript  = data.RejoinLoad end
        if data.FontSizeMode   then UISettings.FontSizeMode= data.FontSizeMode end
        ok=true
    end)
    return ok
end

