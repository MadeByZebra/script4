        end)
        lbl.Position=UDim2.new(0,20,0,0); lbl.Size=UDim2.new(1,-40,1,0)
    end
    local arrow=Instance.new("TextLabel",row); arrow.Size=UDim2.new(0,16,1,0)
    arrow.Position=UDim2.new(1,-22,0,0); arrow.BackgroundTransparency=1
    arrow.Text="›"; arrow.TextColor3=C_MUTED(); arrow.TextSize=16; arrow.Font=Enum.Font.GothamBold; arrow.TextXAlignment=Enum.TextXAlignment.Center
    local loading=false
    local hitbox=Instance.new("TextButton",row); hitbox.Size=UDim2.new(1,0,1,0)
    hitbox.BackgroundTransparency=1; hitbox.Text=""; hitbox.ZIndex=2
    if tooltipText then attachTooltip(hitbox,tooltipText) end
    hitbox.MouseEnter:Connect(function() row.BackgroundColor3=Color3.fromRGB(35,40,55); row.BackgroundTransparency=0 end)
    hitbox.MouseLeave:Connect(function() row.BackgroundTransparency=1 end)
    hitbox.MouseButton1Click:Connect(function()
        if loading then return end; logAction("Pressed — "..labelText)
        if confirmMsg and UISettings.ConfirmDialogs then
            showConfirm("Confirm Action",confirmMsg,function() if callback then callback() end end)
        else if callback then callback() end end
    end)
    local function setLoading(on,loadText)
        loading=on
        if on then lbl.Text=(loadText or "Loading..."); lbl.TextColor3=C_MUTED(); arrow.Text="⏳"
        else lbl.Text=labelText; lbl.TextColor3=C_TEXT(); arrow.Text="›" end
    end
    return row,setLoading
