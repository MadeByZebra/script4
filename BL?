end
task.spawn(function()
    pcall(function()
        local joinData=Player:GetJoinData(); local td=joinData and joinData.TeleportData
        if td and td.autoLoad and td.scriptUrl and td.scriptUrl~="" then
            task.wait(3); Notify("Auto Rejoin — Reloading","Reloading after rejoin...",4,C_ACCENT()); task.wait(1)
            pcall(function() loadstring(game:HttpGetAsync(td.scriptUrl))() end)
        end
    end)
end)
local function startAutoRejoin()
