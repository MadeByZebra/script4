local function serializeConfig()
    local cfg = {
        Theme=CurrentThemeName, FontSizeMode=UISettings.FontSizeMode,
        CompactSidebar=UISettings.CompactSidebar, DimOverlay=UISettings.DimOverlay,
        ConfirmDialogs=UISettings.ConfirmDialogs, ToastPosition=UISettings.ToastPosition,
        RejoinDelay=AutoRejoin.Delay, RejoinMethod=AutoRejoin.Method, RejoinLoad=AutoRejoin.LoadScript,
        ReconnectDelay=AutoReconnect.Delay, ClashKeybind=ClashSettings.ClashKeybind.Name,
        CameraKeybind=CameraSettings.LockOnKeybind.Name, UIKeybind=RayfieldKeybind.Key.Name,
        CheatsheetKey=KeybindCheatsheetKey.Name, Favorites=Favorites,
        DexBox=dexSelectedBox, BagHighlight=BagHighlightEnabled,
    }
    return HttpService:JSONEncode(cfg)
end
local function deserializeConfig(str)
    local ok, cfg = pcall(function() return HttpService:JSONDecode(str) end)
    if not ok or type(cfg)~="table" then return false end
    pcall(function()
        if cfg.Theme and Themes[cfg.Theme] then applyTheme(cfg.Theme) end
        if cfg.FontSizeMode    then UISettings.FontSizeMode    = cfg.FontSizeMode end
        if cfg.CompactSidebar~=nil then UISettings.CompactSidebar = cfg.CompactSidebar end
        if cfg.DimOverlay~=nil then UISettings.DimOverlay      = cfg.DimOverlay end
        if cfg.ConfirmDialogs~=nil then UISettings.ConfirmDialogs = cfg.ConfirmDialogs end
        if cfg.ToastPosition   then UISettings.ToastPosition   = cfg.ToastPosition end
        if cfg.RejoinDelay     then AutoRejoin.Delay            = cfg.RejoinDelay end
        if cfg.RejoinMethod    then AutoRejoin.Method           = cfg.RejoinMethod end
        if cfg.RejoinLoad~=nil then AutoRejoin.LoadScript       = cfg.RejoinLoad end
        if cfg.ReconnectDelay  then AutoReconnect.Delay         = cfg.ReconnectDelay end
        if cfg.ClashKeybind    then pcall(function() ClashSettings.ClashKeybind   = Enum.KeyCode[cfg.ClashKeybind]   end) end
        if cfg.CameraKeybind   then pcall(function() CameraSettings.LockOnKeybind = Enum.KeyCode[cfg.CameraKeybind]  end) end
        if cfg.UIKeybind       then pcall(function() RayfieldKeybind.Key           = Enum.KeyCode[cfg.UIKeybind]      end) end
        if cfg.CheatsheetKey   then pcall(function() KeybindCheatsheetKey          = Enum.KeyCode[cfg.CheatsheetKey]  end) end
        if cfg.Favorites and type(cfg.Favorites)=="table" then Favorites=cfg.Favorites end
        if cfg.DexBox          then dexSelectedBox    = cfg.DexBox end
        if cfg.BagHighlight~=nil then BagHighlightEnabled = cfg.BagHighlight end
    end)
    return true
end

-- =============================================
--// MACRO RECORDER
-- =============================================
local MacroRecorder = { Recording=false, Playing=false, Macros={}, CurrentRec=nil }
local lastInputTime  = 0

local function startMacroRecording(name)
    if MacroRecorder.Recording then return end
    MacroRecorder.Recording=true
    MacroRecorder.CurrentRec={name=name,actions={},startTime=os.clock()}
    logAction("Macro REC started: "..name)
end
local function stopMacroRecording()
    if not MacroRecorder.Recording then return end
    MacroRecorder.Recording=false
    if MacroRecorder.CurrentRec then
        table.insert(MacroRecorder.Macros, MacroRecorder.CurrentRec)
        pcall(function()
            ensureFolder("ZebraBoxingLeague")
            writefile("ZebraBoxingLeague/macros.json", HttpService:JSONEncode(MacroRecorder.Macros))
        end)
        logAction("Macro saved: "..MacroRecorder.CurrentRec.name)
    end
    MacroRecorder.CurrentRec=nil
end
local function playMacro(macro)
    if MacroRecorder.Playing then return end
    MacroRecorder.Playing=true
    task.spawn(function()
        local startT = os.clock(); local cumulative = 0
        for _, action in ipairs(macro.actions) do
            cumulative = cumulative + (action.delay or 0)
            local waitUntil = startT + cumulative
            local now = os.clock()
            if waitUntil > now then task.wait(waitUntil - now) end
            if action.type=="key" then
                pcall(function()
                    local kc = Enum.KeyCode[action.key]
                    if kc then VIM:SendKeyEvent(true,kc,false,game); task.wait(0.05); VIM:SendKeyEvent(false,kc,false,game) end
                end)
            elseif action.type=="click" then
                pcall(function()
                    VIM:SendMouseButtonEvent(action.x,action.y,0,true,game,1); task.wait(0.05)
                    VIM:SendMouseButtonEvent(action.x,action.y,0,false,game,1)
                end)
            end
        end
        MacroRecorder.Playing=false; logAction("Macro played: "..macro.name)
    end)
end
UIS.InputBegan:Connect(function(inp)
    if not MacroRecorder.Recording or not MacroRecorder.CurrentRec then return end
    if inp.UserInputType==Enum.UserInputType.Keyboard then
        local now = os.clock()
        local delay = (lastInputTime==0) and 0 or (now-lastInputTime)
        lastInputTime = now
        table.insert(MacroRecorder.CurrentRec.actions,{type="key",key=inp.KeyCode.Name,delay=delay})
    end
end)
pcall(function()
    if isfile("ZebraBoxingLeague/macros.json") then
        local d = HttpService:JSONDecode(readfile("ZebraBoxingLeague/macros.json"))
        for _,m in ipairs(d) do table.insert(MacroRecorder.Macros,m) end
    end
end)

