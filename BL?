        {label="Anti AFK",    get=function() return AntiAFK.Enabled end,          toggle=function() AntiAFK.Enabled=not AntiAFK.Enabled; if AntiAFK.Enabled then startAFK() else stopAFK() end end},
        {label="Noclip",      get=function() return NoclipSettings.Enabled end,   toggle=function() NoclipSettings.Enabled=not NoclipSettings.Enabled; setNoclip(NoclipSettings.Enabled) end},
