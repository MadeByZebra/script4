--// CAMERA  — FIX: moved into a module table to avoid register overflow
-- =============================================
local CamMod = {}

function CamMod.freeze()
    if CameraSettings.CurrentlyFrozen then return end
    CameraSettings.CurrentlyFrozen=true; CameraSettings.FrozenCFrame=Camera.CFrame
    Camera.CameraType=Enum.CameraType.Scriptable
    CameraSettings.RenderConnection=RunService.RenderStepped:Connect(function()
        if CameraSettings.CurrentlyFrozen and CameraSettings.FrozenCFrame then
            Camera.CameraType=Enum.CameraType.Scriptable; Camera.CFrame=CameraSettings.FrozenCFrame
        end
    end)
end

function CamMod.unfreeze()
    if not CameraSettings.CurrentlyFrozen then return end
    CameraSettings.CurrentlyFrozen=false; CameraSettings.FrozenCFrame=nil
    if CameraSettings.RenderConnection then CameraSettings.RenderConnection:Disconnect(); CameraSettings.RenderConnection=nil end
    Camera.CameraType=Enum.CameraType.Custom
end

function CamMod.isLockedOn()
    local s=Camera.CameraSubject; if not s then return false end
    local c=Player.Character; if not c then return false end
    return not(s:IsDescendantOf(c) or s==c)
end

function CamMod.startWatcher()
    if CameraSettings.SubjectConnection then return end
    CameraSettings.SubjectConnection=Camera:GetPropertyChangedSignal("CameraSubject"):Connect(function()
        if not CameraSettings.BrokenCamera then return end
        if CamMod.isLockedOn() then CamMod.freeze(); Notify("Locked On — Frozen","Camera held.",2,C_ACCENT())
        else CamMod.unfreeze(); Notify("Lock Off — Restored","Normal camera.",2,C_MUTED()) end
    end)
end

function CamMod.stopWatcher()
    if CameraSettings.SubjectConnection then CameraSettings.SubjectConnection:Disconnect(); CameraSettings.SubjectConnection=nil end
    CamMod.unfreeze()
end

-- Keep original names for backwards compat inside tab builders
local freezeCamera        = function() CamMod.freeze() end
local unfreezeCamera      = function() CamMod.unfreeze() end
local isLockedOn          = function() return CamMod.isLockedOn() end
local startLockOnWatcher  = function() CamMod.startWatcher() end
local stopLockOnWatcher   = function() CamMod.stopWatcher() end

UIS.InputBegan:Connect(function(inp,gp)
    if gp then return end; if not CameraSettings.BrokenCamera then return end
    if inp.KeyCode==CameraSettings.LockOnKeybind then
        if CameraSettings.CurrentlyFrozen then unfreezeCamera() else freezeCamera() end
    end
end)

