            local char=Player.Character; if not char then return end
            for _,part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then part.CanCollide=false end
            end
        end)
    else
        if NoclipSettings.Connection then NoclipSettings.Connection:Disconnect(); NoclipSettings.Connection=nil end
        local char=Player.Character
        if char then for _,part in ipairs(char:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide=true end end end
    end
end

