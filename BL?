--// DRAGGING + SNAPPING
-- =============================================
do
    local dragging=false; local dragStart,startPos
    Topbar.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            dragging=true; dragStart=inp.Position; startPos=Root.Position
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then
            local d=inp.Position-dragStart
            Root.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
            if not dragging then return end; dragging=false; saveWindowState(Root.Position,Root.AbsoluteSize)
            local vp=workspace.CurrentCamera.ViewportSize
            local ap=Root.AbsolutePosition; local as=Root.AbsoluteSize; local snap=40
            local nx,ny=ap.X,ap.Y
            if ap.X<snap then nx=0 end; if ap.Y<snap then ny=0 end
            if (ap.X+as.X)>(vp.X-snap) then nx=vp.X-as.X end
            if (ap.Y+as.Y)>(vp.Y-snap) then ny=vp.Y-as.Y end
            if nx~=ap.X or ny~=ap.Y then TweenService:Create(Root,TweenInfo.new(0.18,Enum.EasingStyle.Quart),{Position=UDim2.new(0,nx,0,ny)}):Play() end
        end
    end)
end

