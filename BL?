local notifCount=0
local function Notify(title,content,duration,color)
    notifCount=notifCount+1; duration=duration or 3; color=color or C_ACCENT()
    addToNotifHistory(title,content,color)
    local card=Instance.new("Frame",NotifStack)
    card.Size=UDim2.new(1,0,0,60); card.BackgroundColor3=C_SIDEBAR()
    card.BackgroundTransparency=0.08; card.BorderSizePixel=0; card.LayoutOrder=notifCount
    makeRound(card,8); makeStroke(card,C_STROKE(),1)
    local bar=Instance.new("Frame",card); bar.Size=UDim2.new(0,3,1,-14)
    bar.Position=UDim2.new(0,0,0,7); bar.BackgroundColor3=color; bar.BorderSizePixel=0; makeRound(bar,2)
    local tl=Instance.new("TextLabel",card); tl.Size=UDim2.new(1,-16,0,20)
    tl.Position=UDim2.new(0,14,0,10); tl.BackgroundTransparency=1; tl.Text=title
    tl.TextColor3=C_TEXT(); tl.TextSize=fs(12); tl.Font=Enum.Font.GothamBold; tl.TextXAlignment=Enum.TextXAlignment.Left
    local bl=Instance.new("TextLabel",card); bl.Size=UDim2.new(1,-16,0,20)
    bl.Position=UDim2.new(0,14,0,32); bl.BackgroundTransparency=1; bl.Text=content
    bl.TextColor3=C_MUTED(); bl.TextSize=fs(10); bl.Font=Enum.Font.Gotham
    bl.TextXAlignment=Enum.TextXAlignment.Left; bl.TextTruncate=Enum.TextTruncate.AtEnd
    task.delay(duration,function()
        if card and card.Parent then
            local tw=TweenService:Create(card,TweenInfo.new(0.2,Enum.EasingStyle.Quart,Enum.EasingDirection.In),{BackgroundTransparency=1})
            tw:Play(); tw.Completed:Wait(); card:Destroy()
        end
    end)
end

