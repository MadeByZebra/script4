local ExternalOverlays={}

local function createExternalOverlay(title,lines,accentColor)
    accentColor=accentColor or C_ACCENT()
    local gui=Instance.new("ScreenGui"); gui.Name="Overlay_"..title:gsub("%s","")
    gui.ResetOnSpawn=false; gui.DisplayOrder=1002; gui.IgnoreGuiInset=true
    gui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling; gui.Parent=playerGui
    local win=Instance.new("Frame",gui)
    win.Size=UDim2.new(0,200,0,30+#lines*22+8)
    win.Position=UDim2.new(0,20+#ExternalOverlays*210,0,80)
    win.BackgroundColor3=C_BG(); win.BorderSizePixel=0; win.Active=true
    makeRound(win,8); makeStroke(win,C_STROKE(),1)
    local topBar=Instance.new("Frame",win); topBar.Size=UDim2.new(1,0,0,3)
    topBar.BackgroundColor3=accentColor; topBar.BorderSizePixel=0; makeRound(topBar,8)
    local tbFill=Instance.new("Frame",topBar); tbFill.Size=UDim2.new(1,0,0.5,0)
    tbFill.Position=UDim2.new(0,0,0.5,0); tbFill.BackgroundColor3=accentColor; tbFill.BorderSizePixel=0
    local titleBar=Instance.new("Frame",win); titleBar.Size=UDim2.new(1,0,0,26)
    titleBar.Position=UDim2.new(0,0,0,3); titleBar.BackgroundTransparency=1; titleBar.BorderSizePixel=0
    local titleLbl=Instance.new("TextLabel",titleBar); titleLbl.Size=UDim2.new(1,-30,1,0)
    titleLbl.Position=UDim2.new(0,10,0,0); titleLbl.BackgroundTransparency=1; titleLbl.Text=title
    titleLbl.TextColor3=C_TEXT(); titleLbl.TextSize=fs(11); titleLbl.Font=Enum.Font.GothamBold; titleLbl.TextXAlignment=Enum.TextXAlignment.Left
    local closeBtn=Instance.new("TextButton",titleBar); closeBtn.Size=UDim2.new(0,16,0,16)
    closeBtn.Position=UDim2.new(1,-20,0.5,-8); closeBtn.BackgroundColor3=Color3.fromRGB(239,68,68)
    closeBtn.Text="✕"; closeBtn.TextColor3=Color3.fromRGB(255,255,255); closeBtn.TextSize=8
    closeBtn.Font=Enum.Font.GothamBold; closeBtn.BorderSizePixel=0; makeRound(closeBtn,8)
    local div=Instance.new("Frame",win); div.Size=UDim2.new(1,-16,0,1)
    div.Position=UDim2.new(0,8,0,30); div.BackgroundColor3=C_STROKE(); div.BorderSizePixel=0
    local labelRefs={}
    for i,line in ipairs(lines) do
        local lbl=Instance.new("TextLabel",win); lbl.Size=UDim2.new(1,-16,0,18)
        lbl.Position=UDim2.new(0,8,0,34+(i-1)*22); lbl.BackgroundTransparency=1
        lbl.Text=line; lbl.TextColor3=C_MUTED(); lbl.TextSize=fs(10)
        lbl.Font=Enum.Font.GothamMedium; lbl.TextXAlignment=Enum.TextXAlignment.Left
        lbl.TextTruncate=Enum.TextTruncate.AtEnd; table.insert(labelRefs,lbl)
    end
    do
        local dg=false; local ds,ws
        titleBar.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then dg=true; ds=inp.Position; ws=win.Position end
        end)
        UIS.InputChanged:Connect(function(inp)
            if dg and inp.UserInputType==Enum.UserInputType.MouseMovement then
                local d=inp.Position-ds; win.Position=UDim2.new(ws.X.Scale,ws.X.Offset+d.X,ws.Y.Scale,ws.Y.Offset+d.Y)
            end
        end)
        UIS.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then dg=false end end)
    end
    closeBtn.MouseButton1Click:Connect(function()
        gui:Destroy()
        for i,e in ipairs(ExternalOverlays) do if e.gui==gui then table.remove(ExternalOverlays,i); break end end
    end)
    local entry={gui=gui,labels=labelRefs,win=win}
    table.insert(ExternalOverlays,entry); return entry
end

