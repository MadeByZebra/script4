    track.BackgroundColor3=C_CARD(); track.BorderSizePixel=0; makeRound(track,7); makeStroke(track,C_STROKE(),1)
    local fill=Instance.new("Frame",track); fill.Size=UDim2.new((current-min)/(max-min),0,1,0)
    fill.BackgroundColor3=C_ACCENT(); fill.BorderSizePixel=0; makeRound(fill,7)
