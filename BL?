local function fs(size)
    local scale = 1.0
    if UISettings.FontSizeMode=="Small"  then scale=0.85
    elseif UISettings.FontSizeMode=="Large" then scale=1.2 end
    return math.max(8, math.floor(size*scale))
end
local function makeRound(p,r)  local c=Instance.new("UICorner",p); c.CornerRadius=UDim.new(0,r or 6); return c end
local function makeStroke(p,col,th) local s=Instance.new("UIStroke",p); s.Color=col or C_STROKE(); s.Thickness=th or 1; return s end
local function makePadding(p,t,b,l,r)
    local pad=Instance.new("UIPadding",p)
    pad.PaddingTop=UDim.new(0,t or 0); pad.PaddingBottom=UDim.new(0,b or 0)
    pad.PaddingLeft=UDim.new(0,l or 0); pad.PaddingRight=UDim.new(0,r or 0); return pad
end
local function makeList(p,dir,pad,sort)
    local l=Instance.new("UIListLayout",p)
    l.FillDirection=dir or Enum.FillDirection.Vertical
    l.SortOrder=sort or Enum.SortOrder.LayoutOrder
    l.Padding=UDim.new(0,pad or 0); return l
end

