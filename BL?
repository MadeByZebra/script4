-- Resize handles
local MIN_W,MIN_H,MAX_W,MAX_H=560,360,1100,700
local function addResizeHandle(parent,edge)
    local handle=Instance.new("TextButton",parent); handle.BackgroundTransparency=1
    handle.Text=""; handle.ZIndex=20; handle.BorderSizePixel=0
    local resizing=false; local startPos,startSize
    if edge=="right" then
        handle.Size=UDim2.new(0,6,1,-20); handle.Position=UDim2.new(1,-6,0,10)
        handle.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then resizing=true; startPos=inp.Position; startSize=Root.AbsoluteSize end
        end)
        UIS.InputChanged:Connect(function(inp)
            if resizing and inp.UserInputType==Enum.UserInputType.MouseMovement then
                Root.Size=UDim2.new(0,math.clamp(startSize.X+(inp.Position.X-startPos.X),MIN_W,MAX_W),0,Root.AbsoluteSize.Y)
            end
        end)
    elseif edge=="bottom" then
        handle.Size=UDim2.new(1,-20,0,6); handle.Position=UDim2.new(0,10,1,-6)
        handle.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then resizing=true; startPos=inp.Position; startSize=Root.AbsoluteSize end
        end)
        UIS.InputChanged:Connect(function(inp)
            if resizing and inp.UserInputType==Enum.UserInputType.MouseMovement then
                Root.Size=UDim2.new(0,Root.AbsoluteSize.X,0,math.clamp(startSize.Y+(inp.Position.Y-startPos.Y),MIN_H,MAX_H))
            end
        end)
    elseif edge=="corner" then
        handle.Size=UDim2.new(0,12,0,12); handle.Position=UDim2.new(1,-12,1,-12)
        local corner=Instance.new("TextLabel",handle); corner.Size=UDim2.new(1,0,1,0)
        corner.BackgroundTransparency=1; corner.Text="⌟"; corner.TextColor3=C_MUTED(); corner.TextSize=14
        corner.Font=Enum.Font.GothamBold; corner.TextXAlignment=Enum.TextXAlignment.Right; corner.TextYAlignment=Enum.TextYAlignment.Bottom
        handle.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then resizing=true; startPos=inp.Position; startSize=Root.AbsoluteSize end
        end)
        UIS.InputChanged:Connect(function(inp)
            if resizing and inp.UserInputType==Enum.UserInputType.MouseMovement then
                Root.Size=UDim2.new(0,math.clamp(startSize.X+(inp.Position.X-startPos.X),MIN_W,MAX_W),0,math.clamp(startSize.Y+(inp.Position.Y-startPos.Y),MIN_H,MAX_H))
            end
        end)
    end
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 and resizing then
            resizing=false; saveWindowState(Root.Position,Root.AbsoluteSize)
        end
    end)
    return handle
end
addResizeHandle(Root,"right"); addResizeHandle(Root,"bottom"); addResizeHandle(Root,"corner")

