local function getButtonValue(btn)
    if not btn then return nil end; local MC=btn:FindFirstChild("MC"); if not MC then return nil end
    local MXVal=MC:FindFirstChild("MX"); if not MXVal then return nil end; return MXVal.Value
end
local function isButtonDone(btn) local val=getButtonValue(btn); return val==nil or val<=0 end
local function allButtonsDone(ZN)
